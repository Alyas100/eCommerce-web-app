generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  googleId  String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  addresses Address[]
  cartItems CartItem[]
  orders    Order[]

  @@map("users")
}

model Product {
  image_url   String
  name        String
  price       Decimal     @db.Decimal(10, 2)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  category_id String
  id          String      @id @default(cuid())
  cartItems   CartItem[]
  orderItems  OrderItem[]
  categories  categories  @relation(fields: [category_id], references: [id], map: "products_categoryid_fkey")

  @@map("products")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  user        User        @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  street    String
  city      String
  state     String
  zipCode   String
  country   String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])

  @@map("addresses")
}

model categories {
  id       String    @id
  name     String    @unique
  products Product[]
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
